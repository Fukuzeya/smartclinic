# SmartClinic — production env file (HTTP-only, IP-hosted demo).
#
# Copy to /opt/smartclinic/.env on the server (bootstrap.sh does this for
# you) and fill in every CHANGE_ME value. Then `chmod 600` it.
#
# ⚠️  This template serves plain HTTP on a public IP. That is fine for
# the academic demo at http://172.236.3.27 but must NOT be used for
# real patient data — OIDC tokens and PII would travel unencrypted.
# Swap in a domain + the HTTPS Caddyfile before production use.

# ─── Public host (IP or bare hostname, no scheme, no trailing slash) ────
DEPLOY_HOST=172.236.3.27

# ─── GHCR pull credentials (owner = GitHub user/org that owns the repo) ──
REGISTRY=ghcr.io
IMAGE_OWNER=CHANGE_ME_github_owner
IMAGE_TAG=latest

# ─── Postgres ────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password

# ─── RabbitMQ ────────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=smartclinic
RABBITMQ_DEFAULT_PASS=CHANGE_ME_strong_random_password

# ─── Keycloak admin ──────────────────────────────────────────────────────
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_long_random_admin_password

# --- Observability (Grafana basicauth via Caddy) -------------------------
# Generate the hash on the server, then paste it below, escaping every '$'
# as '$$' so docker compose does NOT treat it as a variable reference:
#   docker run --rm caddy:2.8-alpine caddy hash-password --plaintext '<password>'
# Example output: $2a$14$xyz... -> paste as $$2a$$14$$xyz...
# Leave blank until you have a real hash (Grafana endpoint stays unprotected).
GRAFANA_BASICAUTH_USER=ops
GRAFANA_BASICAUTH_HASH=

# ─── Optional AI copilot (ADR-0013) ──────────────────────────────────────
# Leave BLANK to use the deterministic MockClinicalCopilot.
ANTHROPIC_API_KEY=

# ─── Optional: off-host backups to S3-compatible storage ────────────────
# Leave BACKUP_S3_BUCKET empty to disable.
BACKUP_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1

# ─── OIDC issuer (public URL the browser sees) ───────────────────────────
# Must match exactly what Keycloak emits in JWT `iss` claims.
OIDC_ISSUER=http://${DEPLOY_HOST}/auth/realms/smartclinic
