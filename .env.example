# SmartClinic — environment variables.
#
# Copy to `.env` for local development. Docker Compose reads this file
# automatically. Every key below is consumed by the shared_kernel Settings
# class or a concrete service settings subclass.

# --- Runtime ------------------------------------------------------------------
ENVIRONMENT=local
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_SUPERUSER=smartclinic
POSTGRES_SUPERUSER_PASSWORD=change-me-in-production

# Each bounded context gets its own database (see ops/postgres/init.sql).
# Default roles mirror the database names; passwords overridable per service.
PATIENT_IDENTITY_DB_URL=postgresql+asyncpg://patient_identity:patient_identity@postgres:5432/patient_identity
SCHEDULING_DB_URL=postgresql+asyncpg://scheduling:scheduling@postgres:5432/scheduling
CLINICAL_WRITE_DB_URL=postgresql+asyncpg://clinical:clinical@postgres:5432/clinical_write
CLINICAL_READ_DB_URL=postgresql+asyncpg://clinical:clinical@postgres:5432/clinical_read
PHARMACY_DB_URL=postgresql+asyncpg://pharmacy:pharmacy@postgres:5432/pharmacy
LABORATORY_DB_URL=postgresql+asyncpg://laboratory:laboratory@postgres:5432/laboratory
BILLING_DB_URL=postgresql+asyncpg://billing:billing@postgres:5432/billing
SAGA_DB_URL=postgresql+asyncpg://saga:saga@postgres:5432/saga

# --- RabbitMQ -----------------------------------------------------------------
RABBITMQ_URL=amqp://smartclinic:smartclinic@rabbitmq:5672/
RABBITMQ_MANAGEMENT_URL=http://rabbitmq:15672
SMARTCLINIC_EXCHANGE=smartclinic.events
SMARTCLINIC_DLX=smartclinic.events.dlx

# --- Keycloak / OIDC ----------------------------------------------------------
KEYCLOAK_BASE_URL=http://keycloak:8080
KEYCLOAK_REALM=smartclinic
OIDC_ISSUER=http://keycloak:8080/realms/smartclinic
OIDC_JWKS_URL=http://keycloak:8080/realms/smartclinic/protocol/openid-connect/certs
OIDC_AUDIENCE=smartclinic-api
OIDC_CLIENT_ID=smartclinic-api
OIDC_CLIENT_SECRET=change-me

# --- OpenTelemetry ------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_SERVICE_NAMESPACE=smartclinic
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local

# --- Mail (Mailhog in dev) ----------------------------------------------------
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=noreply@smartclinic.local

# --- Outbox relay -------------------------------------------------------------
OUTBOX_POLL_INTERVAL_SECONDS=2.0
OUTBOX_BATCH_SIZE=100
OUTBOX_MAX_ATTEMPTS=12
